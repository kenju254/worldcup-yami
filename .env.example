# ==============================================================================
# World Cup 2026 Tracking Application - Environment Variables Template
# Copy this file to '.env' in the root directory (for Next.js) and
# to 'functions/.env' (for Python Flask functions).
# ==============================================================================

# Backend API Configuration (functions/.env)
# ------------------------------------------------------------------------------
# API Key for API-Football (from api-sports.io)
FOOTBALL_API_KEY=your_api_sports_key_here

# API Key for YouTube Data API v3 (from Google Cloud Console)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Season configuration (default is 2022 for demo data, 2026 for tournament)
CURRENT_SEASON=2022

# Frontend Configuration (.env)
# ------------------------------------------------------------------------------
# Target Audience URL for Service-to-Service OIDC Authentication
# In production, this matches the Cloud Run URL of the backend.
TARGET_AUDIENCE=https://api-jwiz3cw7wq-uc.a.run.app
